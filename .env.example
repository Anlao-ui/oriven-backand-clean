# ═══════════════════════════════════════════════════════════════
# ORIVEN — Environment Variable Reference
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env (never commit .env — it is gitignored).
# In production, set these variables in the Render dashboard:
#   Render → Service → Environment → Environment Variables
#
# KEY TYPES:
#   BACKEND-ONLY  — secrets, never exposed to the browser
#   FRONTEND-SAFE — public values, safe in client-side code
# ═══════════════════════════════════════════════════════════════


# ── Supabase ─────────────────────────────────────────────────────
# FRONTEND-SAFE: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# BACKEND-ONLY: Supabase Dashboard → Settings → API → service_role key (labeled DANGER)
# Must be the service_role JWT, NOT the anon/publishable key.
SUPABASE_SERVICE_ROLE_KEY=eyJ...


# ── Stripe ───────────────────────────────────────────────────────
# BACKEND-ONLY: Stripe Dashboard → Developers → API keys → Secret key
# Use sk_test_... locally, sk_live_... in production.
STRIPE_SECRET_KEY=sk_live_...

# BACKEND-ONLY: Stripe Dashboard → Developers → Webhooks → endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# BACKEND-ONLY: Stripe Dashboard → Products → each plan → Pricing → Price ID
# Steps: Stripe Dashboard → Products → Create product → Add price (recurring, monthly, EUR)
#        Copy the price_... ID and paste below.
#
# Current plan pricing:
#   Starter      → €9.95/month
#   Creator      → €29.95/month  (Most Popular)
#   Professional → €59.95/month
#   Agency       → Contact Sales — no Stripe price ID (handled via mailto:hello@oriven.ai)
#
# Replace with real Stripe Price IDs before going live:
STRIPE_PRICE_STARTER=               # e.g. price_1TrfNQ066sCcz3jQR7H1CD30
STRIPE_PRICE_CREATOR=               # e.g. price_1TrfNl066sCcz3jQmHdTsqiI
STRIPE_PRICE_PROFESSIONAL=          # e.g. price_1TrfO5066sCcz3jQN2MWXWBP


# ── AI / LLM ─────────────────────────────────────────────────────
# BACKEND-ONLY: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# BACKEND-ONLY: platform.openai.com → API keys
OPENAI_API_KEY=sk-...

# BACKEND-ONLY: app.heygen.com → Settings → API → API Key
HEYGEN_API_KEY=sk_V2_...


# ── SMTP / Email ──────────────────────────────────────────────────
# BACKEND-ONLY: Transactional email for verification and invites.
# Defaults to Outlook SMTP if HOST/PORT are omitted.
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_USER=you@outlook.com
SMTP_PASS=your-app-password

# Optional display name in From: header. Defaults to: ORIVEN <SMTP_USER>
SMTP_FROM=ORIVEN <no-reply@orivenai.com>


# ── Google OAuth + Ads ───────────────────────────────────────────
# BACKEND-ONLY: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# BACKEND-ONLY: Google Ads UI → Tools → API Centre
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token

# BACKEND-ONLY: Must match an Authorized redirect URI in Google Cloud Console.
# Auto-detected if unset: localhost:5500 (local) or Render URL (production).
# Always set this explicitly in Render environment variables.
GOOGLE_REDIRECT_URI=https://oriven-backand-clean.onrender.com/auth/google/callback


# ── App ───────────────────────────────────────────────────────────
# BACKEND-ONLY: Public frontend URL for Stripe redirects and email links.
# The Google OAuth redirect auto-detects local vs production WITHOUT this var —
# only set it if you change the frontend domain.
# Default if unset (production/Render): https://orivenai.com
# Default if unset (local dev):         http://localhost:5500
FRONTEND_URL=https://orivenai.com
